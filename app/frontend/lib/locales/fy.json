          "other": "%{count} dagen"
        },
        "x_minutes": {
          "one": "1 minút",
          "other": "%{count} minuten"
        },
        "x_months": {
          "one": "1 moanne",
          "other": "%{count} moannen"
        },
        "x_seconds": {
          "one": "1 sekonde",
          "other": "%{count} sekonden"
        },
        "x_years": {
          "one": "1 jier",
          "other": "%{count} jier"
        }
