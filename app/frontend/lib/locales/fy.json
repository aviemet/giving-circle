        "about_x_months": {
          "one": "likernôch 1 moanne",
          "other": "likernôch %{count} moannen"
        },
        "about_x_years": {
          "one": "likernôch 1 jier",
          "other": "likernôch %{count} jier"
        },
        "almost_x_years": {
          "one": "hast 1 jier",
          "other": "hast %{count} jier"
        },
        "half_a_minute": "in heale minút",
