          "one": "minder as in minút",
          "other": "minder as %{count} minuten"
        },
        "less_than_x_seconds": {
          "one": "minder as 1 sekonde",
          "other": "minder as %{count} sekonden"
        },
        "over_x_years": {
          "one": "mear as 1 jier",
          "other": "mear as %{count} jier"
        },
        "x_days": {
