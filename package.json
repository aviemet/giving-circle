    "@mantine/rte": "^5.10.5",
    "@mantine/tiptap": "^9.1.1",
    "@mantine/vanilla-extract": "^9.1.1",
    "@measured/puck": "^0.20.2",
    "@rails/actioncable": "^8.1.300",
    "@rails/activestorage": "^8.1.300",
