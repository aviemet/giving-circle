{
  "name": "giving-circle",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/aviemet/giving-circle.git",
  "description": "Facilitate giving",
  "author": "Avram Walden <aviemet@gmail.com>",
  "license": "MIT",
  "packageManager": "yarn@4.9.1",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "RACK_ENV=production RAILS_ENV=production PORT=3000 NODE_ENV=production overmind start -f Procfile",
    "dev": "RAILS_ENV=development PORT=3000 NODE_ENV=development overmind start -f Procfile.dev",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "eslint:inspect": "npx @eslint/config-inspector@latest",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:once": "vitest run",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "test:browser:headed": "BROWSER_HEADED=1 vitest --config=vitest.browser.config.ts",
    "coverage": "vitest run --coverage",
    "rspec": "RAILS_ENV=test bundle exec rspec --color",
    "rspec:watch": "RAILS_ENV=test bundle exec rake rspec_watcher:watch",
    "verify": "yarn lint:fix && yarn test:once && yarn rspec",
    "regenerate": "rails types:generate && rails annotate:all && rails i18n:export"
  },
  "dependencies": {
    "@fragaria/address-formatter": "^6.7.1",
    "@inertiajs/react": "^3.0.3",
